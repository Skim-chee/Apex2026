---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Process — Jeremy and Seean's Ceramics">
  <section class="process-hero">
    <h2 class="process-heading">Process & Inspiration</h2>
    <p class="process-sub">A moodboard of textures, references, and studio moments.</p>
  </section>

  <section class="grid">
    <!-- Replace these placeholders with actual images -->
    <div class="image-placeholder tall">
      <span class="placeholder-label">Image</span>
    </div>
    <div class="image-placeholder">
      <span class="placeholder-label">Image</span>
    </div>
    <div class="image-placeholder">
      <span class="placeholder-label">Image</span>
    </div>
    <div class="image-placeholder wide">
      <span class="placeholder-label">Image</span>
    </div>
    <div class="image-placeholder">
      <span class="placeholder-label">Image</span>
    </div>
    <div class="image-placeholder tall">
      <span class="placeholder-label">Image</span>
    </div>
    <div class="image-placeholder">
      <span class="placeholder-label">Image</span>
    </div>
    <div class="image-placeholder wide">
      <span class="placeholder-label">Image</span>
    </div>
  </section>
</BaseLayout>

<style>
  .process-hero {
    text-align: center;
    padding: 5rem 0 3rem;
  }

  .process-heading {
    font-family: 'Cormorant Garamond', serif;
    font-weight: 300;
    font-size: clamp(1.8rem, 4vw, 2.8rem);
    letter-spacing: 0.06em;
    color: #2c2c2c;
    margin-bottom: 0.8rem;
  }

  .process-sub {
    font-size: 1rem;
    color: #8a8a8a;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.75rem;
    padding-bottom: 4rem;
  }

  .image-placeholder {
    background: #eae8e4;
    border-radius: 2px;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 200px;
  }

  .placeholder-label {
    font-size: 0.75rem;
    color: #b0ada8;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .tall {
    grid-row: span 2;
  }

  .wide {
    grid-column: span 2;
  }

  @media (max-width: 600px) {
    .grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .wide {
      grid-column: span 2;
    }
  }
</style>
