---
import BaseLayout from '../layouts/BaseLayout.astro';
import videoSrc from '../assets/moodboard.mp4';
---

<BaseLayout title="Process — Jeremy and Seean's Ceramics">
  <section class="process-hero">
    <h2 class="process-heading">Process & Inspiration</h2>
    <p class="process-sub">A moodboard of textures, references, and studio moments.</p>
  </section>

  <section class="video-section">
    <video
      id="moodboard-video"
      src={videoSrc}
      muted
      loop
      playsinline
      preload="metadata"
    />
  </section>
</BaseLayout>

<script>
  const video = document.getElementById('moodboard-video') as HTMLVideoElement;

  const observer = new IntersectionObserver(
    ([entry]) => {
      if (entry.isIntersecting) {
        video.play();
      } else {
        video.pause();
      }
    },
    { threshold: 0.2 }
  );

  observer.observe(video);
</script>

<style>
  .process-hero {
    text-align: center;
    padding: 5rem 0 3rem;
  }

  .process-heading {
    font-family: 'Cormorant Garamond', serif;
    font-weight: 300;
    font-size: clamp(1.8rem, 4vw, 2.8rem);
    letter-spacing: 0.06em;
    color: #2c2c2c;
    margin-bottom: 0.8rem;
  }

  .process-sub {
    font-size: 1rem;
    color: #8a8a8a;
  }

  .video-section {
    padding-bottom: 4rem;
  }

  video {
    width: 100%;
    border-radius: 2px;
    display: block;
  }
</style>
